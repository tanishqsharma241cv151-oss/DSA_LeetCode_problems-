class Solution{
public:
    int subarraysWithXorK(vector<int> &nums, int k) {
        int count=0;
        unordered_map<int,int>mpp;
        int xr=0;
        mpp[0]=1;
        for(int i=0;i<nums.size();i++){
            xr^=nums[i];
            int x= xr^k;
            count+=mpp[x];
            mpp[xr]++;    
        }
        return count;
    }
};
